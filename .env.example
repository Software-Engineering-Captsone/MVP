# ─── Supabase (required for auth) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — server-only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App URL (used for OAuth redirect URIs) ─────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── SMTP (school email OTP verification) ───────────
# Used by /api/verify/school-email/send for athlete .edu OTP codes.
# For Gmail SMTP, create a Google App Password and use the full Gmail
# address for SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password
SMTP_FROM="NILINK <your-email@gmail.com>"

# ─── Social OAuth ────────────────────────────────────
# Instagram / Meta App
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# TikTok Developer App
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# YouTube (Google OAuth — youtube.readonly scope)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─── Legacy (no longer required — kept for reference) ─
# MONGODB_URI=mongodb+srv://...
# JWT_SECRET=your-super-secret-jwt-key
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-gmail-app-password
# Inbox for /talk-to-sales form (defaults to EMAIL_USER if unset).
# CONTACT_SALES_TO=sales@yourcompany.com
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Data layer — defaults to live Supabase via /api/marketplace/* and /api/saved.
# Override per-surface to fall back to bundled fixtures / browser localStorage:
#   NEXT_PUBLIC_MARKETPLACE_DATA_SOURCE=mock  → use bundled mockAthletes / mockBrands
#   NEXT_PUBLIC_SAVED_DATA_SOURCE=local       → use browser localStorage saved lists

# Watch Demo page (/watch-demo) — set one of:
# YouTube/Vimeo watch or embed URL (recommended for tutorials hosted on YouTube).
# NEXT_PUBLIC_DEMO_VIDEO_EMBED_URL=https://www.youtube.com/embed/VIDEO_ID
# Direct MP4 URL (e.g. after upload to Supabase Storage or a CDN).
# NEXT_PUBLIC_DEMO_VIDEO_URL=
# Optional poster image for the HTML5 video element.
# NEXT_PUBLIC_DEMO_VIDEO_POSTER_URL=
