# MongoDB — optional. Auth and campaigns use local JSON under /data when unset.
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/nilink?retryWrites=true&w=majority&appName=Cluster0

# JWT — required. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key

# Local auth store (auto-created): data/local-users-store.json
# Local campaign store (auto-created): data/local-campaign-store.json

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email — use a Gmail App Password (not your regular password)
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Data layer — leave unset for bundled mock + browser localStorage (default dev).
# Set to `api` to read marketplace rows from /api/marketplace/* and saved profiles from /api/saved.
# NEXT_PUBLIC_MARKETPLACE_DATA_SOURCE=api
# NEXT_PUBLIC_SAVED_DATA_SOURCE=api
